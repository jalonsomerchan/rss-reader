# Override the default site URL if needed.
ASTRO_SITE=https://example.com
PUBLIC_SITE_URL=https://example.com

# Use / for root domains or /nombre-repo for subfolder deployments.
ASTRO_BASE=/

# Optional: pin the PWA cache version. By default each build gets a fresh version.
# PUBLIC_CACHE_VERSION=2026-06-26-1

# Override the repository link shown in the starter UI.
PUBLIC_REPOSITORY_URL=https://github.com/usuario/nombre-repo
