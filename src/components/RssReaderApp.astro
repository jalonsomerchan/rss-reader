---
import '../styles/reader.css';
import '../styles/reader-menu.css';
import '../styles/reader-menu-pages.css';
import '../styles/reader-main-menu-pages.css';
import '../styles/reader-news.css';
import '../styles/reader-filter-history.css';
import '../styles/reader-loading.css';
import '../styles/reader-sticky-header.css';
import '../styles/reader-desktop-layout.css';
import '../styles/reader-pull-refresh.css';
import { rssConfig } from '../config/rss';
import type { Locale } from '../config/site';
import { useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const flatCategoriesScriptUrl = `${baseUrl}scripts/rss-flat-categories.js`;
const readerScriptUrl = `${baseUrl}scripts/rss-reader.js`;
const menuEnhancementsScriptUrl = `${baseUrl}scripts/rss-menu-enhancements.js`;
const mainMenuPagesScriptUrl = `${baseUrl}scripts/rss-main-menu-pages.js`;
const pullRefreshScriptUrl = `${baseUrl}scripts/rss-pull-refresh.js`;
const imageFallbackScriptUrl = `${baseUrl}scripts/rss-image-fallback.js`;
const filterHistoryScriptUrl = `${baseUrl}scripts/rss-filter-history.js`;
const labels = {
  allCategories: t('reader.categoryFilter.all'),
  copiedLink: t('reader.copiedLink'),
  errorLoading: t('reader.errorLoading'),
  filterCategory: t('reader.categoryFilter.aria'),
  filterSource: t('reader.sourceFilter.aria'),
  justNow: t('reader.justNow'),
  menuBack: t('reader.menu.back'),
  menuCategoryResult: t('reader.menu.categoryResult'),
  menuSearchEmpty: t('reader.menu.searchEmpty'),
  menuSearchResults: t('reader.menu.searchResults'),
  menuSourceResult: t('reader.menu.sourceResult'),
  noMoreNews: t('reader.noMoreNews'),
  otherCategories: t('reader.categoryGroups.other'),
  otherSources: t('reader.sourceGroups.other'),
  readyStatus: t('reader.readyStatus'),
  removeSaved: t('reader.removeSaved'),
  saveArticle: t('reader.saveArticle'),
  saved: t('reader.saved'),
  savedArticle: t('reader.savedArticle'),
  savedCategories: t('reader.savedCategories'),
  selectOneCategory: t('reader.selectOneCategory'),
  settingsHint: t('reader.settings.hint'),
  share: t('reader.share'),
  shareError: t('reader.shareError'),
  viewSource: t('reader.viewSource'),
  viewSourceAria: t('reader.viewSource.aria'),
};
---

<section
  class="reader-shell"
  data-rss-reader
  data-api-base={rssConfig.apiBase}
  data-storage-key={rssConfig.storageKey}
  data-page-size={rssConfig.pageSize}
  data-archive-month-lookback={rssConfig.archiveMonthLookback}
  data-archive-source-batch-size={rssConfig.archiveSourceBatchSize}
  data-locale={locale}
  data-labels={JSON.stringify(labels)}
>
  <div class="reader-surface">
    <header class="reader-appbar">
      <div class="reader-brand">
        <span class="reader-brand__mark" aria-hidden="true">R</span>
        <span>{t('reader.app.name')}</span>
      </div>
      <div class="reader-appbar__actions">
        <span class="reader-appbar__status">
          <span aria-hidden="true"></span>
          {t('reader.app.status')}
        </span>
        <div class="reader-menu" data-reader-menu>
          <button
            class="reader-menu__toggle"
            type="button"
            data-menu-toggle
            aria-expanded="false"
            aria-controls="reader-filter-menu"
            aria-label={t('reader.menu.open')}
          >
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
          </button>
          <div class="reader-menu__panel" id="reader-filter-menu" data-menu-panel hidden>
            <div class="reader-menu__header">
              <div>
                <p class="reader-eyebrow">{t('reader.menu.eyebrow')}</p>
                <h2>{t('reader.menu.title')}</h2>
              </div>
              <button class="reader-menu__close" type="button" data-menu-close>
                {t('reader.menu.close')}
              </button>
            </div>

            <div class="reader-menu__page reader-menu__page--home" data-menu-page="home">
              <div class="reader-menu-search" role="search">
                <label for="reader-menu-search">{t('reader.menu.search')}</label>
                <input
                  id="reader-menu-search"
                  type="search"
                  data-menu-search-input
                  list="reader-menu-search-options"
                  autocomplete="off"
                  placeholder={t('reader.menu.searchPlaceholder')}
                />
                <datalist id="reader-menu-search-options" data-menu-search-options></datalist>
                <div class="reader-menu-search__results" data-menu-search-results hidden aria-live="polite"></div>
              </div>

              <div class="reader-menu__quick-links" aria-label={t('reader.menu.shortcuts')}>
                <button class="reader-menu__shortcut" type="button" data-main-view-target="my-categories">
                  {t('reader.menu.myCategories')}
                </button>
                <button class="reader-menu__shortcut" type="button" data-main-view-target="my-sources">
                  {t('reader.menu.mySources')}
                </button>
              </div>

              <details class="reader-menu__section" open>
                <summary>{t('reader.menu.categories')}</summary>
                <div class="reader-menu__content" data-menu-categories></div>
              </details>
              <details class="reader-menu__section">
                <summary>{t('reader.menu.sources')}</summary>
                <div class="reader-menu__content" data-menu-sources></div>
              </details>
            </div>
          </div>
        </div>
      </div>
    </header>

    <section class="reader-panel reader-onboarding" data-onboarding hidden>
      <div>
        <p class="reader-eyebrow">{t('reader.setup.eyebrow')}</p>
        <h2>{t('reader.setup.title')}</h2>
        <p>{t('reader.setup.description')}</p>
      </div>
      <div class="category-grid" data-category-list="setup" aria-label={t('reader.categoriesLabel')}></div>
      <button class="reader-primary-action" type="button" data-save-categories="setup">
        {t('reader.saveSelection')}
      </button>
    </section>

    <div class="reader-app" data-reader-app>
      <div class="reader-pull-refresh" data-pull-refresh hidden aria-live="polite">
        <span class="reader-pull-refresh__spinner" aria-hidden="true"></span>
        <span>{t('reader.loading')}</span>
      </div>

      <div class="reader-topic-strip" data-selected-categories aria-label={t('reader.selectedCategoriesLabel')}></div>

      <nav class="reader-tabs" role="tablist" aria-label={t('reader.tabs.label')}>
        <button type="button" role="tab" data-tab="mine" aria-selected="true">
          <span>{t('reader.tabs.mine')}</span>
        </button>
        <button type="button" role="tab" data-tab="all" aria-selected="false">
          <span>{t('reader.tabs.all')}</span>
        </button>
        <button type="button" role="tab" data-tab="saved" aria-selected="false">
          <span>{t('reader.tabs.saved')}</span>
        </button>
        <button type="button" role="tab" data-tab="settings" aria-selected="false">
          <span>{t('reader.tabs.settings')}</span>
        </button>
      </nav>

      <div class="reader-feedback">
        <p class="reader-status" data-status aria-live="polite"></p>
        <p class="reader-loading" data-loading hidden>{t('reader.loading')}</p>
        <p class="reader-processing" data-processing-indicator hidden aria-live="polite" aria-atomic="true">
          {t('reader.processing')}
        </p>
      </div>

      <section class="reader-feed-panel" data-panel="mine">
        <div class="reader-section-heading">
          <h2>{t('reader.mine.title')}</h2>
          <p>{t('reader.mine.description')}</p>
        </div>
        <div class="news-list" data-list="mine"></div>
        <p class="reader-empty" data-empty="mine" hidden>{t('reader.empty.mine')}</p>
      </section>

      <section class="reader-feed-panel" data-panel="all" hidden>
        <div class="reader-section-heading">
          <h2>{t('reader.all.title')}</h2>
          <p>{t('reader.all.description')}</p>
        </div>
        <div class="news-list" data-list="all"></div>
        <p class="reader-empty" data-empty="all" hidden>{t('reader.empty.all')}</p>
      </section>

      <section class="reader-feed-panel" data-panel="saved" hidden>
        <div class="reader-section-heading">
          <h2>{t('reader.saved.title')}</h2>
          <p>{t('reader.saved.description')}</p>
        </div>
        <div class="news-list" data-list="saved"></div>
        <p class="reader-empty" data-empty="saved" hidden>{t('reader.empty.saved')}</p>
      </section>

      <section class="reader-panel reader-menu-main-page" data-main-view="my-categories" tabindex="-1" hidden>
        <div class="reader-section-heading">
          <p class="reader-eyebrow">{t('reader.menu.categories')}</p>
          <h2>{t('reader.menu.myCategories')}</h2>
          <p>{t('reader.menu.myCategoriesDescription')}</p>
        </div>
        <div class="reader-main-filter-list" data-main-page-categories></div>
      </section>

      <section class="reader-panel reader-menu-main-page" data-main-view="my-sources" tabindex="-1" hidden>
        <div class="reader-section-heading">
          <p class="reader-eyebrow">{t('reader.menu.sources')}</p>
          <h2>{t('reader.menu.mySources')}</h2>
          <p>{t('reader.menu.mySourcesDescription')}</p>
        </div>
        <div class="reader-main-filter-list" data-main-page-sources></div>
      </section>

      <section class="reader-panel reader-settings" data-panel="settings" hidden>
        <div>
          <p class="reader-eyebrow">{t('reader.settings.eyebrow')}</p>
          <h2>{t('reader.settings.title')}</h2>
          <p>{t('reader.settings.description')}</p>
        </div>
        <div class="category-grid" data-category-list="settings" aria-label={t('reader.categoriesLabel')}></div>
        <div class="reader-settings-block">
          <div>
            <h3>{t('reader.ignoredSources.title')}</h3>
            <p>{t('reader.ignoredSources.description')}</p>
          </div>
          <div class="source-grid" data-source-list="settings" aria-label={t('reader.ignoredSources.label')}></div>
          <p class="reader-empty reader-empty--compact" data-empty-ignored-sources hidden>
            {t('reader.ignoredSources.empty')}
          </p>
        </div>
        <button class="reader-primary-action" type="button" data-save-categories="settings">
          {t('reader.saveSelection')}
        </button>
      </section>

      <button class="reader-load-more" type="button" data-load-more hidden>{t('reader.loadMore')}</button>
      <div class="reader-sentinel" data-sentinel aria-hidden="true"></div>
    </div>
  </div>
</section>

<script type="module" src={flatCategoriesScriptUrl}></script>
<script type="module" src={readerScriptUrl}></script>
<script type="module" src={menuEnhancementsScriptUrl}></script>
<script type="module" src={mainMenuPagesScriptUrl}></script>
<script type="module" src={pullRefreshScriptUrl}></script>
<script type="module" src={imageFallbackScriptUrl}></script>
<script type="module" src={filterHistoryScriptUrl}></script>
