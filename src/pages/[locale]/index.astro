---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RssReaderApp from '../../components/RssReaderApp.astro';
import { defaultLocale, locales, siteConfig, type Locale } from '../../config/site';
import { isLocale, useTranslations } from '../../i18n/ui';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({
      params: { locale },
    }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const t = useTranslations(locale);
---

<BaseLayout title={t('home.title')} description={t('site.description')} locale={locale}>
  <RssReaderApp locale={locale} />
  <a class="sr-only" href={siteConfig.repositoryUrl}>{t('home.repository')}</a>
</BaseLayout>
