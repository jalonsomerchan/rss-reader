---
import BaseLayout from '../layouts/BaseLayout.astro';
import RssReaderApp from '../components/RssReaderApp.astro';
import { defaultLocale, siteConfig } from '../config/site';
import { useTranslations } from '../i18n/ui';

const locale = defaultLocale;
const t = useTranslations(locale);
---

<BaseLayout title={t('home.title')} description={t('site.description')} locale={locale} appShell>
  <RssReaderApp locale={locale} />
  <a class="sr-only" href={siteConfig.repositoryUrl}>{t('home.repository')}</a>
</BaseLayout>
